NODE_ENV=development
PORT=8080
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yor_tokens
REDIS_URL=redis://localhost:6379

# OIDC / auth provider. Use Clerk/Auth0/Cognito/Supabase JWTs; never extension-only auth.
AUTH_ISSUER=https://issuer.example.com/
AUTH_AUDIENCE=yor-token-usage-api
AUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json

# Comma-separated extension origins. Example: chrome-extension://abcdefghijklmnopabcdefghijklmnop
ALLOWED_EXTENSION_ORIGINS=chrome-extension://YOUR_EXTENSION_ID

# HMAC secret for hashing IPs/user-agents in logs. Use 32+ random bytes.
LOG_HASH_SECRET=replace-with-random-secret

# Optional bearer token for /metrics. Keep private to monitoring only.
METRICS_BEARER_TOKEN=replace-with-random-token

# Optional KMS envelope key id. Do not store raw user API keys without envelope encryption.
KMS_KEY_ID=
